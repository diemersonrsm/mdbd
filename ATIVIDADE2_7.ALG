Algoritmo "atividade2_7"

var
   nume, limite, i, resu: inteiro

inicio

   escreva("Digite o número da tabuada: ")
   leia(numero)

   escreva("Digite o limite final: ")
   leia(limite)

   para i de 1 ate limite faca
      resultado <- nume * i
      escreval(nume, " x ", i, " = ", resu)
   fimpara
fimalgoritmo